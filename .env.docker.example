# 生产环境 Docker 部署 — 复制为 .env 后修改
JWT_SECRET=请替换为至少32位随机字符串

# 首次部署空数据卷时设为 true，从 prisma/init.db 初始化；已有业务数据必须为 false
INIT_DB=true

# 版本升级后设为 true 可自动执行业绩/客户状态回填（可选，也可手动 docker compose run）
RUN_SYNC=false

# 对外端口（宿主机 Nginx 反代时可仅映射 127.0.0.1:3000）
APP_PORT=3000

# 启用 compose 中的 Nginx 服务（docker compose --profile nginx up -d）
# NGINX_HTTP_PORT=80
