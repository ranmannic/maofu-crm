# 应用端口（宿主机映射）
APP_PORT=3001

# 会话签名密钥（生产环境请使用强随机字符串，至少 32 位）
JWT_SECRET="change-this-in-production"

# 首次部署空库时可设为 true，写入演示账号；生产环境请保持 false
AUTO_SEED=false

# npm 镜像（Docker 构建用，默认 npmmirror 国内加速）
NPM_REGISTRY=https://registry.npmmirror.com

# 空数据卷时从 prisma/init.db 复制（需事先 npm run db:export-init 生成）
INIT_DB=false

# 启动时执行业绩与客户状态回填（版本升级后推荐设为 true，完成后改回 false）
RUN_SYNC=false

# Cookie Secure 标志：HTTP 访问设为 false；HTTPS 访问设为 true（或依赖 Nginx X-Forwarded-Proto）
COOKIE_SECURE=false

# 业务数据目录（宿主机绝对路径；数据库与上传文件均存于此目录下）
DATA_DIR=/data/service/maofu/maofu_crm/maofu_crm_data

# 分享链接公网地址（可选；未设置时由请求 Host 自动推断）
# NEXT_PUBLIC_APP_URL=http://crm.maofujiuzhuang.com
