{
  "name": "maofu-crm",
  "version": "0.6.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:init": "tsx prisma/init-db.ts",
    "db:export-init": "tsx prisma/export-init-db.ts",
    "db:sync-performance": "tsx prisma/sync-performance.ts",
    "db:sync-customer-status": "tsx prisma/sync-customer-status.ts",
    "db:clear-orders": "tsx prisma/clear-orders.ts",
    "db:reset": "prisma migrate reset --force",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
