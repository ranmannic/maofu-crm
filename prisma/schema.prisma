generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  SALES
  OPERATIONS
  ADMIN
}

enum SpecUnit {
  BOTTLE
  BOX
  PIECE
  SET
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum CreditOrderStatus {
  ACTIVE
  SETTLED
  BAD_DEBT
}

enum RefundStatus {
  NONE
  PARTIAL
  FULL
}

enum PerformanceRecordType {
  COLLECT
  REFUND
}

enum CustomerFollowUpStatus {
  ACTIVE
  ABANDONED
}

enum CustomerStatus {
  LEAD
  CLOSED
}

enum ShippingMethod {
  PICKUP
  SELF_DELIVERY
  EXPRESS
  LOGISTICS
  ON_SITE_STOCKING
}

enum ReconciliationReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderVoucherCategory {
  CONTRACT
  SIGN_OFF
  CHAT
  PAYMENT
  OTHER
}

enum DeviceKind {
  MOBILE
  DESKTOP
}

enum AppEdition {
  STANDARD
  PREMIUM
}

model AppSetting {
  id                    String     @id @default("global")
  edition               AppEdition @default(STANDARD)
  premiumTrialStartedAt DateTime?
  premiumTrialEndsAt    DateTime?
  premiumSubscribedAt   DateTime?
  monthlyFixedCost      Float      @default(0)
  updatedAt             DateTime   @updatedAt
  updatedById           String?
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customers     Customer[]
  salesOrders   Order[]       @relation("SalesOrders")
  handledOrders Order[]       @relation("HandledOrders")
  sessions      UserSession[]
}

model UserSession {
  id         String     @id @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceKind DeviceKind
  expiresAt  DateTime
  createdAt  DateTime   @default(now())

  @@unique([userId, deviceKind])
  @@index([userId])
}

model ChannelType {
  id        String        @id @default(cuid())
  name      String        @unique
  sortOrder Int           @default(0)
  parentId  String?
  parent    ChannelType?  @relation("ChannelHierarchy", fields: [parentId], references: [id])
  children  ChannelType[] @relation("ChannelHierarchy")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  customers Customer[]
}

model Customer {
  id        String       @id @default(cuid())
  name      String
  phone     String?
  channelId String?
  channel   ChannelType? @relation(fields: [channelId], references: [id])
  address   String?
  salesId   String
  sales     User         @relation(fields: [salesId], references: [id])
  deletedAt DateTime?
  followUpStatus CustomerFollowUpStatus @default(ACTIVE)
  customerStatus CustomerStatus         @default(LEAD)
  abandonedAt   DateTime?
  abandonReason String?
  followUpNotes String?
  birthday      String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  orders            Order[]
  creditInventories CustomerInventory[]
  followUpRecords   CustomerFollowUpRecord[]
  shippingAddresses CustomerShippingAddress[]
  pricePolicyNotes  CustomerPricePolicyNote[]
}

model CustomerPricePolicyNote {
  id            String   @id @default(cuid())
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productSpecId String
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([customerId, productSpecId])
  @@index([customerId])
}

model CustomerShippingAddress {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name       String
  phone      String
  province   String?
  city       String?
  county     String?
  address    String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([customerId, isDefault])
}

model CustomerFollowUpRecord {
  id             String   @id @default(cuid())
  customerId     String
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  userId         String
  userName       String
  followedAt     DateTime
  content        String
  nextPlan       String?
  nextFollowUpAt DateTime?
  createdAt      DateTime @default(now())

  @@index([customerId, followedAt])
  @@index([nextFollowUpAt])
}

model Product {
  id             String   @id @default(cuid())
  name           String
  description    String?
  alcoholContent String?
  aromaType      String?
  origin         String?
  thumbnailKey   String?
  shareToken     String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  specs  ProductSpec[]
  images ProductImage[]
}

model ProductImage {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  storageKey String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([productId, sortOrder])
}

model ProductSpec {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  unitType  SpecUnit @default(BOTTLE)
  bottlesPerUnit Int @default(1)
  price     Float
  cost      Float    @default(0)
  retailGuidePrice    Float?
  retailFloorPrice    Float?
  groupGuidePrice     Float?
  groupFloorPrice     Float?
  wholesaleGuidePrice Float?
  wholesaleFloorPrice Float?
  description       String?
  thumbnailKey      String?
  stockQty          Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems OrderItem[]
}

model Order {
  id                 String    @id @default(cuid())
  orderNo            String    @unique
  customerId         String
  customer           Customer  @relation(fields: [customerId], references: [id])
  customerName       String
  salesId            String
  sales              User      @relation("SalesOrders", fields: [salesId], references: [id])
  handlerId          String?
  handler            User?     @relation("HandledOrders", fields: [handlerId], references: [id])
  productAmount      Float         @default(0)
  shippingFee        Float         @default(0)
  otherFee           Float         @default(0)
  calculatedAmount   Float         @default(0)
  totalAmount        Float
  amountAdjustReason String?
  productCostTotal   Float         @default(0)
  paymentStatus      PaymentStatus @default(UNPAID)
  isPaid             Boolean       @default(false)
  paidAmount         Float         @default(0)
  isShipped          Boolean   @default(false)
  orderedAt          DateTime  @default(now())
  paidAt             DateTime?
  notes              String?
  deletedAt          DateTime?
  creditStatus       CreditOrderStatus?
  badDebtAmount      Float?
  badDebtGoodsRecovered Boolean?
  badDebtNotes       String?
  refundStatus       RefundStatus  @default(NONE)
  refundAmount       Float         @default(0)
  refundedAt         DateTime?
  shareToken         String?       @unique
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  items                  OrderItem[]
  shipping               ShippingInfo?
  auditLogs              OrderAuditLog[]
  creditLines            OrderCreditLine[]
  reconciliationRecords  CreditReconciliationRecord[]
  performanceRecords     PerformanceRecord[]
  vouchers               OrderVoucher[]
}

model OrderVoucher {
  id             String               @id @default(cuid())
  orderId        String
  order          Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  category       OrderVoucherCategory
  fileName       String
  mimeType       String
  storageKey     String
  uploadedById   String
  uploadedByName String
  createdAt      DateTime             @default(now())

  @@index([orderId])
}

model OrderItem {
  id            String      @id @default(cuid())
  orderId       String
  order         Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  productSpecId String
  productSpec   ProductSpec @relation(fields: [productSpecId], references: [id])
  productName   String
  specName      String
  unitType      SpecUnit    @default(BOTTLE)
  quantity      Int
  unitPrice     Float
  unitCost      Float       @default(0)
  isGift        Boolean     @default(false)
}

model ShippingInfo {
  id             String          @id @default(cuid())
  orderId        String          @unique
  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method         ShippingMethod?
  recipientName  String?
  recipientPhone String?
  province       String?
  city           String?
  county         String?
  customerAddressId String?
  carrier        String?
  trackingNo     String?
  address        String?
  shippedAt      DateTime?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model OrderAuditLog {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId    String
  userName  String
  action    String
  changes   String?
  createdAt DateTime @default(now())
}

model CustomerInventory {
  id              String   @id @default(cuid())
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId       String
  productSpecId   String
  productName     String
  specName        String
  unitType        SpecUnit @default(BOTTLE)
  unreconciledQty Int      @default(0)
  reconciledQty   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([customerId, productSpecId])
}

model OrderCreditLine {
  id                  String   @id @default(cuid())
  orderId             String
  order               Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItemId         String   @unique
  customerId          String
  productSpecId       String
  productName         String
  specName            String
  unitType            SpecUnit @default(BOTTLE)
  orderQty            Int
  unreconciledQty     Int      @default(0)
  reconciledQty       Int      @default(0)
  badDebtRecoveredQty Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model CreditReconciliationRecord {
  id                String                       @id @default(cuid())
  orderId           String
  order             Order                        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId        String
  userId            String
  userName          String
  action            String
  paidAmount        Float                        @default(0)
  paymentStatus     PaymentStatus                @default(UNPAID)
  performanceAmount Float                        @default(0)
  paidAt            DateTime?
  detail            String?
  reviewStatus      ReconciliationReviewStatus   @default(APPROVED)
  reviewedById      String?
  reviewedByName    String?
  reviewedAt        DateTime?
  rejectReason      String?
  createdAt         DateTime                     @default(now())

  performanceRecord PerformanceRecord?
}

model PerformanceRecord {
  id                     String                  @id @default(cuid())
  orderId                String
  order                  Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  salesId                String
  amount                 Float
  type                   PerformanceRecordType
  eventAt                DateTime
  reconciliationRecordId String?                 @unique
  reconciliationRecord   CreditReconciliationRecord? @relation(fields: [reconciliationRecordId], references: [id], onDelete: SetNull)
  detail                 String?
  createdAt              DateTime                @default(now())

  @@index([salesId, eventAt, type])
  @@index([orderId])
}
